# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/elyto?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/elyto?schema=public"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (login + Gmail scopes use separate client configs in production)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Elyto <hello@elyto.in>"

# Redis (BullMQ + rate limiting)
REDIS_URL="redis://localhost:6379"

# Encryption (32-byte key, base64-encoded)                                  
ENCRYPTION_KEY="generate-with-openssl-rand-base64-32"

# Peppers for hashing
API_KEY_PEPPER="replace-with-strong-random-string"
WEBHOOK_SECRET_PEPPER="replace-with-strong-random-string"
WEBHOOK_SECRET="replace-with-strong-random-string"

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Seed (optional) — set to your email to grant platform admin on seed
SEED_ADMIN_EMAIL=""

# UploadThing (project logos)
UPLOADTHING_TOKEN=""

# Error monitoring (optional)
SENTRY_DSN=""

# Worker / Scheduler
WORKER_PORT="3001"
SCHEDULER_PORT="3002"
PAYMENT_WORKER_CONCURRENCY="5"
GMAIL_WORKER_CONCURRENCY="3"
WEBHOOK_WORKER_CONCURRENCY="10"
ANALYTICS_WORKER_CONCURRENCY="1"
BILLING_WORKER_CONCURRENCY="1"
ACCOUNT_WORKER_CONCURRENCY="1"
PAYMENT_QUEUE_ATTEMPTS="5"
GMAIL_QUEUE_ATTEMPTS="3"
WEBHOOK_QUEUE_ATTEMPTS="8"
GMAIL_SYNC_CRON="*/10 * * * *"
ANALYTICS_CRON="0 0 * * *"
BILLING_RESET_CRON="0 2 * * *"
LOG_LEVEL="info"
